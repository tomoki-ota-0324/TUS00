FROM ubuntu:18.04

RUN apt-get update \
  && apt-get -y upgrade \
  && apt-get install -y locales python3.7 python3.7-dev python3.7-distutils default-libmysqlclient-dev build-essential vim curl \
  && curl https://bootstrap.pypa.io/get-pip.py -o get-pip.py \
  && python3.7 get-pip.py --user \
  && echo 'export PATH=$PATH:$HOME/.local/bin' >> ~/.bashrc \
  && mkdir /src \
  && mkdir /src/STP00-dev \
  && rm -rf /var/lib/apt/lists/* \
  && echo "ja_JP UTF-8" > /etc/locale.gen \
  && locale-gen

SHELL ["/bin/bash", "-c", "source ~/.bashrc"]

COPY --chown=root:root ./STP00-dev /src/STP00-dev

# COPY ./app/entrypoint.sh /usr/bin/

WORKDIR /src/STP00-dev

RUN pip3 install -r requirements/local.txt

CMD ["python3.7"]

# 軽量化のため、ubuntuベースでDockerファイルを作成したが、pipについてpython3.7対応がうまくできないため本Dockerファイルは使用しない
